# Environment Variables for Receipt Reconciliation OpenEnv
# Copy this file to .env and fill in your actual values

# Required: Hugging Face API token (get from https://huggingface.co/settings/tokens)
HF_TOKEN=your_hf_token_here

# Optional: LLM API endpoint (default: Hugging Face router)
API_BASE_URL=https://router.huggingface.co/v1

# Optional: Model to use for inference (default: Qwen)
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Optional: Environment server URL (default: localhost)
ENV_BASE_URL=http://localhost:7860

# Optional: Enable web interface for the environment
ENABLE_WEB_INTERFACE=true
